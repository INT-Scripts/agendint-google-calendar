# Identifiants de l'école (Agendint)
AGENDINT_LOGIN="votre.pseudo"
AGENDINT_PASSWORD="votre.motdepasse"

# ID du calendrier à scraper (si vide, le premier par défaut sera pris)
# Ex: "PROJETS", "COURS", ou l'ID exact
AGENDINT_CALENDAR_ID=""

# Google Calendar (Optionnel: Laissez vide pour utiliser le calendrier principal)
# Si vous avez créé un agenda dédié, mettez son ID ici (ex: "xxxxxxxx@group.calendar.google.com")
GOOGLE_CALENDAR_ID="primary"
